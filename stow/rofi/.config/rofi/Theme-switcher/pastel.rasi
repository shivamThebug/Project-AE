/* ====================================================
   WAYBAR PORT TO ROFI (FOGGY WHITE / LIGHT GLASS THEME)
   APP LAUNCHER VARIANT
   ==================================================== */
* {
    font:               "SF Pro Display, JetBrainsMono Nerd Font 13";
    background-color:   transparent;
    margin:             0;
    padding:            0;
    bg-container:       rgba(255, 255, 255, 0.45);
    border-container:   rgba(0, 0, 0, 0.07);
    border-item:        rgba(0, 0, 0, 0.06);
    text-normal:        rgba(43, 43, 43, 0.6);
    text-active:        #1A1A2E;
}
window {
    background-color:  @bg-container;
    border:            1px;
    border-color:      @border-container;
    border-radius:     16px;
    width:             400px;
    location:          center;
    anchor:            center;
}
configuration {
    display-drun: "Apps";
    show-icons: true;
}
mainbox {
    children:          [ inputbar, listview ];
    padding:           14px;
    background-color:  transparent;
}
inputbar {
    padding:            10px 18px;
    margin:             0px 0px 10px 0px;
    background-color:   rgba(0, 0, 0, 0.45);
    border:             1px;
    border-color:       @border-item;
    border-radius:      10px;
    children:           [ prompt, entry ];
}
prompt {
    text-color:         @text-normal;
    padding:            0px 10px 0px 0px;
}
entry {
    text-color:         #FFFFFF;
    placeholder:        "Search Apps...";
    placeholder-color:  rgba(255, 255, 255, 0.45);
}
listview {
    lines:             5;
    columns:           1;
    scrollbar:         false;
    spacing:           10px;
    background-color:  transparent;
}
element {
    padding:           10px 18px;
    background-image:  linear-gradient(to bottom, rgba(255, 255, 255, 0.55), rgba(255, 255, 255, 0.35));
    border:            1px;
    border-color:      @border-item;
    border-radius:     10px;
    text-color:        @text-normal;
}
element-text {
    background-color:  transparent;
    text-color:        inherit;
    vertical-align:    0.5;
    font-weight:       500;
}
element-icon {
    background-color:  transparent;
    text-color:        inherit;
    size:              1.2em;
}
element selected {
    background-image:  linear-gradient(to bottom, rgba(255, 255, 255, 0.85), rgba(255, 255, 255, 0.55));
    border:            1px;
    border-color:      rgba(255, 255, 255, 0.9);
    text-color:        @text-active;
}
element-text selected {
    font-weight:       600;
}